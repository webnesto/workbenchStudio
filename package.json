{
  "name": "workbench-studio",
  "displayName": "Workbench Studio",
  "description": "VSCode design customizations: workspace-aware backgrounds, typography overrides, and more. Forked from shalldie/vscode-background.",
  "version": "0.1.4",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "vscode:uninstall": "node ./out/uninstall",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "vsce package --out build/",
    "prepare": "husky"
  },
  "publisher": "eno",
  "author": "eno (forked from shalldie)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shalldie/vscode-background.git"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "icon": "images/logo.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "main": "./out/extension",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "extension.workbenchStudio.info",
        "category": "Workbench Studio",
        "title": "%extension.workbenchStudio.command.info.title%"
      },
      {
        "command": "extension.workbenchStudio.install",
        "category": "Workbench Studio",
        "title": "%extension.workbenchStudio.command.install.title%"
      },
      {
        "command": "extension.workbenchStudio.disable",
        "category": "Workbench Studio",
        "title": "%extension.workbenchStudio.command.disable.title%"
      },
      {
        "command": "extension.workbenchStudio.uninstall",
        "category": "Workbench Studio",
        "title": "%extension.workbenchStudio.command.uninstall.title%"
      },
      {
        "command": "extension.workbenchStudio.openDocs",
        "category": "Workbench Studio",
        "title": "%extension.workbenchStudio.command.openDocs.title%"
      },
      {
        "command": "extension.workbenchStudio.toggleLivePreview",
        "category": "Workbench Studio",
        "title": "%extension.workbenchStudio.command.toggleLivePreview.title%"
      },
      {
        "command": "extension.workbenchStudio.previewPatch",
        "category": "Workbench Studio",
        "title": "[Dev] Preview Patch"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Workbench Studio",
      "properties": {
        "workbenchStudio.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%extension.workbenchStudio.enabled.description%"
        },
        "workbenchStudio.livePreview": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%extension.workbenchStudio.livePreview.description%"
        },
        "workbenchStudio.css": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ],
          "default": "",
          "markdownDescription": "%extension.workbenchStudio.css.description%"
        },
        "workbenchStudio.cssFiles": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ],
          "default": "",
          "markdownDescription": "%extension.workbenchStudio.cssFiles.description%"
        },
        "workbenchStudio.surfaceOpacity": {
          "type": "object",
          "default": {},
          "properties": {
            "editor": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "markdownDescription": "%extension.workbenchStudio.surfaceOpacity.editor%"
            },
            "sidebar": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "markdownDescription": "%extension.workbenchStudio.surfaceOpacity.sidebar%"
            },
            "panel": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "markdownDescription": "%extension.workbenchStudio.surfaceOpacity.panel%"
            },
            "auxiliarybar": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "markdownDescription": "%extension.workbenchStudio.surfaceOpacity.auxiliarybar%"
            }
          },
          "markdownDescription": "%extension.workbenchStudio.surfaceOpacity.description%"
        },
        "workbenchStudio.backgrounds.editor": {
          "type": "object",
          "default": {
            "useFront": true,
            "style": {
              "background-position": "100% 100%",
              "background-size": "auto",
              "opacity": 0.6
            },
            "images": [],
            "interval": 0,
            "random": false,
            "minimapOpacity": 0.8
          },
          "properties": {
            "useFront": {
              "type": "boolean",
              "default": true,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.editor.useFront%"
            },
            "minimapOpacity": {
              "type": "number",
              "default": 0.8,
              "minimum": 0,
              "maximum": 1,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.editor.minimapOpacity%"
            },
            "blendMode": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/blendMode"
            },
            "style": {
              "type": "object",
              "default": {
                "background-position": "100% 100%",
                "background-size": "auto",
                "opacity": 0.6
              },
              "markdownDescription": "%extension.workbenchStudio.backgrounds.editor.style%"
            },
            "images": {
              "type": "array",
              "default": [],
              "items": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "object" }
                ]
              },
              "markdownDescription": "%extension.workbenchStudio.backgrounds.editor.images%"
            },
            "interval": {
              "type": "number",
              "default": 0,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.editor.interval%"
            },
            "random": {
              "type": "boolean",
              "default": false,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.editor.random%"
            }
          },
          "markdownDescription": "%extension.workbenchStudio.backgrounds.editor.description%"
        },
        "workbenchStudio.backgrounds.fullscreen": {
          "type": "object",
          "default": {
            "images": [],
            "opacity": 0.1,
            "size": "cover",
            "position": "center",
            "interval": 0,
            "random": false,
            "style": {}
          },
          "properties": {
            "images": {
              "type": "array",
              "default": [],
              "items": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "object" }
                ]
              },
              "markdownDescription": "%extension.workbenchStudio.backgrounds.editor.images%"
            },
            "opacity": {
              "type": "number",
              "default": 0.1,
              "minimum": 0,
              "maximum": 1,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.fullscreen.opacity%"
            },
            "style": {
              "type": "object",
              "default": {}
            },
            "size": {
              "type": "string",
              "default": "cover",
              "markdownDescription": "%extension.workbenchStudio.backgrounds.fullscreen.size%"
            },
            "position": {
              "type": "string",
              "default": "center",
              "markdownDescription": "%extension.workbenchStudio.backgrounds.fullscreen.position%"
            },
            "interval": {
              "type": "number",
              "default": 0,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.fullscreen.interval%"
            },
            "random": {
              "type": "boolean",
              "default": false,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.fullscreen.random%"
            },
            "useFront": {
              "type": "boolean",
              "default": true,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.fullscreen.useFront%"
            },
            "blendMode": {
              "type": "string",
              "default": "",
              "enum": [
                "",
                "normal",
                "multiply",
                "screen",
                "overlay",
                "darken",
                "lighten",
                "color-dodge",
                "color-burn",
                "hard-light",
                "soft-light",
                "difference",
                "exclusion",
                "hue",
                "saturation",
                "color",
                "luminosity",
                "plus-darker",
                "plus-lighter"
              ],
              "markdownDescription": "%extension.workbenchStudio.backgrounds.section.blendMode%"
            }
          },
          "markdownDescription": "%extension.workbenchStudio.backgrounds.fullscreen.description%"
        },
        "workbenchStudio.backgrounds.sidebar": {
          "type": "object",
          "default": {
            "images": [],
            "opacity": 0.1,
            "size": "cover",
            "position": "center",
            "interval": 0,
            "random": false
          },
          "properties": {
            "images": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/images"
            },
            "opacity": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/opacity"
            },
            "size": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/size"
            },
            "position": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/position"
            },
            "interval": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/interval"
            },
            "random": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/random"
            },
            "useFront": {
              "type": "boolean",
              "default": true,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.section.useFront%"
            },
            "blendMode": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/blendMode"
            }
          },
          "markdownDescription": "%extension.workbenchStudio.backgrounds.sidebar.description%"
        },
        "workbenchStudio.backgrounds.auxiliarybar": {
          "type": "object",
          "default": {
            "images": [],
            "opacity": 0.1,
            "size": "cover",
            "position": "center",
            "interval": 0,
            "random": false
          },
          "properties": {
            "images": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/images"
            },
            "opacity": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/opacity"
            },
            "size": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/size"
            },
            "position": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/position"
            },
            "interval": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/interval"
            },
            "random": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/random"
            },
            "useFront": {
              "type": "boolean",
              "default": true,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.section.useFront%"
            },
            "blendMode": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/blendMode"
            }
          },
          "markdownDescription": "%extension.workbenchStudio.backgrounds.auxiliarybar.description%"
        },
        "workbenchStudio.backgrounds.panel": {
          "type": "object",
          "default": {
            "images": [],
            "opacity": 0.1,
            "size": "cover",
            "position": "center",
            "interval": 0,
            "random": false
          },
          "properties": {
            "images": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/images"
            },
            "opacity": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/opacity"
            },
            "size": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/size"
            },
            "position": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/position"
            },
            "interval": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/interval"
            },
            "random": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/random"
            },
            "useFront": {
              "type": "boolean",
              "default": true,
              "markdownDescription": "%extension.workbenchStudio.backgrounds.section.useFront%"
            },
            "blendMode": {
              "$ref": "#/properties/workbenchStudio.backgrounds.fullscreen/properties/blendMode"
            }
          },
          "markdownDescription": "%extension.workbenchStudio.backgrounds.panel.description%"
        },
        "workbenchStudio.typography.explorer": {
          "type": "object",
          "default": {
            "fontFamily": "",
            "fontSize": 0,
            "fontWeight": "",
            "style": {}
          },
          "properties": {
            "fontFamily": {
              "type": "string",
              "default": "",
              "markdownDescription": "%extension.workbenchStudio.typography.explorer.fontFamily%"
            },
            "fontSize": {
              "type": "number",
              "default": 0,
              "minimum": 0,
              "maximum": 96,
              "markdownDescription": "%extension.workbenchStudio.typography.explorer.fontSize%"
            },
            "fontWeight": {
              "type": "string",
              "default": "",
              "enum": [
                "",
                "normal",
                "bold",
                "100",
                "200",
                "300",
                "400",
                "500",
                "600",
                "700",
                "800",
                "900"
              ],
              "markdownDescription": "%extension.workbenchStudio.typography.explorer.fontWeight%"
            },
            "style": {
              "type": "object",
              "default": {},
              "markdownDescription": "%extension.workbenchStudio.typography.explorer.style%"
            }
          },
          "markdownDescription": "%extension.workbenchStudio.typography.explorer.description%"
        },
        "workbenchStudio.typography.tabs": {
          "type": "object",
          "default": {
            "fontFamily": "",
            "fontSize": 0,
            "fontWeight": "",
            "style": {}
          },
          "properties": {
            "fontFamily": {
              "type": "string",
              "default": "",
              "markdownDescription": "%extension.workbenchStudio.typography.tabs.fontFamily%"
            },
            "fontSize": {
              "type": "number",
              "default": 0,
              "minimum": 0,
              "maximum": 96,
              "markdownDescription": "%extension.workbenchStudio.typography.tabs.fontSize%"
            },
            "fontWeight": {
              "$ref": "#/properties/workbenchStudio.typography.explorer/properties/fontWeight"
            },
            "style": {
              "type": "object",
              "default": {},
              "markdownDescription": "%extension.workbenchStudio.typography.tabs.style%"
            }
          },
          "markdownDescription": "%extension.workbenchStudio.typography.tabs.description%"
        },
        "workbenchStudio.typography.paneTitles": {
          "type": "object",
          "default": {
            "fontFamily": "",
            "fontSize": 0,
            "fontWeight": "",
            "style": {}
          },
          "properties": {
            "fontFamily": {
              "type": "string",
              "default": "",
              "markdownDescription": "%extension.workbenchStudio.typography.paneTitles.fontFamily%"
            },
            "fontSize": {
              "type": "number",
              "default": 0,
              "minimum": 0,
              "maximum": 96,
              "markdownDescription": "%extension.workbenchStudio.typography.paneTitles.fontSize%"
            },
            "fontWeight": {
              "$ref": "#/properties/workbenchStudio.typography.explorer/properties/fontWeight"
            },
            "style": {
              "type": "object",
              "default": {},
              "markdownDescription": "%extension.workbenchStudio.typography.paneTitles.style%"
            }
          },
          "markdownDescription": "%extension.workbenchStudio.typography.paneTitles.description%"
        }
      }
    }
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/node": "^24",
    "@types/stylis": "^4.2.7",
    "@types/uglify-js": "^3.17.5",
    "@types/vscode": "^1.94.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.6",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@vscode/sudo-prompt": "^9.3.1",
    "fast-glob": "^3.3.3",
    "stylis": "^4.3.6",
    "uglify-js": "^3.19.3"
  }
}
